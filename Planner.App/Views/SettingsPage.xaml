<UserControl x:Class="Planner.App.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Planner.App.ViewModels"
             Background="{StaticResource BackgroundDarkBrush}">
    <UserControl.DataContext>
        <vm:SettingsViewModel/>
    </UserControl.DataContext>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="24">
        <StackPanel>
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Настройки" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="Сохранить" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" Padding="18,10"/>
            </Grid>

            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Ассистент и модель" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <TextBlock Text="API Key (OpenAI)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding KeyHint}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,8" MaxLength="4096"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Content="Очистить сохраненный ключ" Command="{Binding ClearSavedApiKeyCommand}" Style="{StaticResource NavButton}" Padding="12,8"/>
                    </StackPanel>

                    <TextBlock Text="Модель" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,8" MaxLength="120"/>
                    <TextBlock Text="Endpoint" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,12" MaxLength="512"/>

                    <CheckBox Content="Разрешить ассистенту читать финансы" IsChecked="{Binding AllowFinanceData}" Style="{StaticResource CheckBoxStyle}" Margin="0,0,0,4"/>
                    <CheckBox Content="Разрешить ассистенту читать цели" IsChecked="{Binding AllowGoalsData}" Style="{StaticResource CheckBoxStyle}" Margin="0,0,0,4"/>
                    <CheckBox Content="Разрешить ассистенту читать напоминания" IsChecked="{Binding AllowRemindersData}" Style="{StaticResource CheckBoxStyle}" Margin="0,0,0,4"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Голосовой ввод" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <TextBlock Text="Горячая клавиша" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding VoiceHotkey, UpdateSourceTrigger=PropertyChanged}" Padding="8" Margin="0,0,0,10" MaxLength="80"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Микрофон" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                            <ComboBox ItemsSource="{Binding VoiceMicrophones}"
                                      DisplayMemberPath="DisplayName"
                                      SelectedValuePath="DeviceNumber"
                                      SelectedValue="{Binding VoiceMicrophoneDeviceNumber, Mode=TwoWay}"
                                      Padding="8"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Обновить" Command="{Binding RefreshMicrophonesCommand}" Style="{StaticResource NavButton}" Padding="12,8" Margin="10,20,0,0"/>
                    </Grid>

                    <CheckBox Content="Озвучивать ответы ассистента после голосового запроса"
                              IsChecked="{Binding VoiceSpeakAssistantResponses}"
                              Style="{StaticResource CheckBoxStyle}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Приложение" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <CheckBox IsChecked="{Binding RunAtStartup}" Content="Запускать Planner вместе с Windows" Style="{StaticResource CheckBoxStyle}" Margin="0,0,0,8"/>
                    <TextBlock Text="Пути" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,8,0,8"/>
                    <TextBlock Text="База данных" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock Text="{Binding DatabasePath}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock Text="Лог диагностики" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <TextBlock Text="{Binding DiagnosticsPath}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource SuccessBrush}" Margin="0,4,0,0"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
