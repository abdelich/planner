<Window x:Class="Planner.App.Views.VoiceAssistantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Голосовой ассистент"
        Width="560"
        Height="520"
        MinWidth="460"
        MinHeight="420"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundDarkBrush}">
    <Border Margin="22" Style="{StaticResource CardBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="Голосовой ввод" FontSize="26" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock x:Name="StatusText" Text="Готовлю микрофон..." Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,24,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Width="96" Height="96" HorizontalAlignment="Left">
                    <Ellipse Fill="#f2f8f3" Stroke="{StaticResource SuccessBrush}" StrokeThickness="2"/>
                    <Ellipse x:Name="MicPulse" Width="58" Height="58" Fill="{StaticResource SuccessBrush}" Opacity="0.18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Text="MIC" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}"/>
                </Grid>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="RecordingText" Text="Слушаю" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                    <ProgressBar x:Name="LevelBar" Height="14" Minimum="0" Maximum="100" Value="0" Foreground="{StaticResource SuccessBrush}" Background="{StaticResource BackgroundHoverBrush}" BorderThickness="0" Margin="0,10,0,0"/>
                    <ProgressBar x:Name="BusyBar" Height="4" IsIndeterminate="True" Visibility="Collapsed" Foreground="{StaticResource AccentBrush}" Background="{StaticResource BackgroundHoverBrush}" BorderThickness="0" Margin="0,12,0,0"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Распознанный текст" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <Border Background="{StaticResource BackgroundHoverBrush}" CornerRadius="8" Padding="12" Margin="0,6,0,14">
                        <TextBlock x:Name="TranscriptText" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" MinHeight="44"/>
                    </Border>

                    <TextBlock Text="Ответ ассистента" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                    <Border Background="{StaticResource BackgroundHoverBrush}" CornerRadius="8" Padding="12" Margin="0,6,0,0">
                        <TextBlock x:Name="AssistantReplyText" TextWrapping="Wrap" Foreground="{StaticResource TextPrimaryBrush}" MinHeight="80"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button x:Name="CancelButton" Content="Отмена" Click="CancelButton_Click" Style="{StaticResource NavButton}" Padding="14,8" Margin="0,0,8,0"/>
                <Button x:Name="StopButton" Content="Остановить и отправить" Click="StopButton_Click" Style="{StaticResource PrimaryButton}" Padding="18,9"/>
                <Button x:Name="CloseButton" Content="Закрыть" Click="CloseButton_Click" Style="{StaticResource PrimaryButton}" Padding="18,9" Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
