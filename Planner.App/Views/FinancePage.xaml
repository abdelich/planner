<UserControl x:Class="Planner.App.Views.FinancePage"
             x:Name="FinancePageRoot"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Planner.App.ViewModels"
             xmlns:models="clr-namespace:Planner.App.Models"
             Background="{StaticResource BackgroundDarkBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid x:Name="RootGrid" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Финансы" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                <Button Content="+ Операция" Command="{Binding OpenAddTransactionCommand}" Style="{StaticResource PrimaryButton}" Margin="24,0,8,0" VerticalAlignment="Center"/>
                <Button Content="Категории" Command="{Binding OpenCategoriesPanelCommand}" Style="{StaticResource NavButton}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <Button Content="Сбережения" Command="{Binding OpenSavingsPanelCommand}" Style="{StaticResource NavButton}" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="{Binding LoadError}" Foreground="#c62828" Margin="0,8,0,0" TextWrapping="Wrap" FontSize="13"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,0,0,24">
                <StackPanel Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="←" Command="{Binding PrevMonthCommand}" Style="{StaticResource NavButton}" Padding="12,6" Margin="0,0,8,0"/>
                <TextBlock Text="{Binding MonthCaption}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Content="→" Command="{Binding NextMonthCommand}" Style="{StaticResource NavButton}" Padding="12,6"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Показывать в:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox SelectedValue="{Binding SelectedCurrency}" SelectedValuePath="Tag" Width="200" Margin="0,0,16,0" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#e0e0e0">
                    <ComboBoxItem Content="Гривны (UAH)" Tag="UAH"/>
                    <ComboBoxItem Content="Кроны (SEK)" Tag="SEK"/>
                    <ComboBoxItem Content="Доллары (USD)" Tag="USD"/>
                </ComboBox>
                <TextBlock Text="Тип:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox SelectedIndex="{Binding SelectedStatsFilterIndex}" Width="120" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#e0e0e0">
                    <ComboBoxItem Content="Все"/>
                    <ComboBoxItem Content="Доходы"/>
                    <ComboBoxItem Content="Расходы"/>
                </ComboBox>
            </StackPanel>
        </StackPanel>

                <Grid Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,8,0" Background="#E8F5E9">
                <StackPanel>
                    <TextBlock Text="Доходы" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,4"/>
                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="#2e7d32">
                        <Run Text="{Binding MonthIncome, StringFormat=N0, Mode=OneWay}"/>
                        <Run Text="{Binding CurrencySymbol, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="4,0" Background="#FFEBEE">
                <StackPanel>
                    <TextBlock Text="Расходы" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,4"/>
                    <TextBlock FontSize="24" FontWeight="Bold" Foreground="#c62828">
                        <Run Text="{Binding MonthExpenses, StringFormat=N0, Mode=OneWay}"/>
                        <Run Text="{Binding CurrencySymbol, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardBorder}" Margin="8,0,0,0" Background="#E3F2FD">
                <StackPanel>
                    <TextBlock Text="Маржа" Foreground="{StaticResource TextSecondaryBrush}" FontSize="13" Margin="0,0,0,4"/>
                    <TextBlock FontSize="24" FontWeight="Bold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MonthMargin}" Value="0">
                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding MonthMargin, StringFormat=N0, Mode=OneWay}"/>
                        <Run Text="{Binding CurrencySymbol, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12" Background="#FFF8E1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="{Binding RefreshRatesButtonText}" Command="{Binding FetchRatesAsyncCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,12,0"/>
                    <TextBlock Text="{Binding RatesDateText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="SEK→UAH:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RateSekToUahText}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,16,0"/>
                    <TextBlock Text="USD→UAH:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RateUsdToUahText}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,16,0"/>
                    <TextBlock Text="USD→SEK:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RateUsdToSekText}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" Margin="0,0,16,0"/>
                    <TextBlock Text="EUR→SEK:" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding RateEurToSekText}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                </StackPanel>
            </StackPanel>
        </Border>

                <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Margin="0,0,8,0">
                <StackPanel>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Доходы по категориям" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding IncomeByCategory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SumText}" Foreground="#2e7d32" FontWeight="SemiBold"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource CardBorder}">
                        <StackPanel>
                            <TextBlock Text="Расходы по категориям" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                            <ItemsControl ItemsSource="{Binding ExpensesByCategory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SumText}" Foreground="#c62828" FontWeight="SemiBold"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Операции за месяц" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                    <ScrollViewer MaxHeight="400" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Transactions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BackgroundHoverBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{Binding CategoryName}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding DateText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding AmountText}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#c62828"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsIncome}" Value="True">
                                                                <Setter Property="Foreground" Value="#2e7d32"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <Button Grid.Column="2" Content="✕" Command="{Binding DataContext.DeleteTransactionCommand, ElementName=RootGrid}" CommandParameter="{Binding}" Style="{StaticResource NavButton}" Foreground="#c62828" Padding="8,4" VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

            </StackPanel>
        </ScrollViewer>

        <Border Grid.RowSpan="2" Panel.ZIndex="5" Background="#CC000000" Visibility="{Binding IsCategoriesPanelOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" MouseDown="Overlay_MouseDown">
            <Border HorizontalAlignment="Center" VerticalAlignment="Stretch" Style="{StaticResource CardBorder}" Width="520" MaxWidth="900" Margin="40" MouseDown="Panel_MouseDown" MaxHeight="700">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Категории доходов и расходов" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="Закрыть" Command="{Binding CloseCategoriesPanelCommand}" Style="{StaticResource NavButton}" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="Здесь можно просматривать, создавать, редактировать и удалять категории для операций." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" TextWrapping="Wrap"/>
                        <Button Content="+ Добавить категорию" Command="{Binding OpenAddCategoryCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,20" HorizontalAlignment="Left" Padding="16,10" FontSize="14"/>
                        <TextBlock Text="Доходы" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding IncomeCategories}" Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BackgroundHoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="Изменить" Command="{Binding DataContext.OpenEditFinanceCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource NavButton}" Padding="6,2" Margin="0,0,4,0"/>
                                                <Button Content="✕ Удалить" Command="{Binding DataContext.DeleteFinanceCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource NavButton}" Foreground="#c62828" Padding="6,2"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Пока нет категорий доходов. Нажмите «+ Добавить категорию» и выберите тип «Доход»." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,20" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IncomeCategories.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="Расходы" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding ExpenseCategories}" Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BackgroundHoverBrush}" CornerRadius="6" Padding="10,8" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="Изменить" Command="{Binding DataContext.OpenEditFinanceCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource NavButton}" Padding="6,2" Margin="0,0,4,0"/>
                                                <Button Content="✕ Удалить" Command="{Binding DataContext.DeleteFinanceCategoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Style="{StaticResource NavButton}" Foreground="#c62828" Padding="6,2"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="Пока нет категорий расходов. Нажмите «+ Добавить категорию» и выберите тип «Расход»." FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,0" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ExpenseCategories.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>

        <Border Grid.RowSpan="2" Panel.ZIndex="10" Background="#CC000000" Visibility="{Binding IsSavingsChartsOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" MouseDown="Overlay_MouseDown">
            <Border HorizontalAlignment="Center" VerticalAlignment="Stretch" Style="{StaticResource CardBorder}" Width="520" MaxWidth="700" Margin="40" MouseDown="Panel_MouseDown" MaxHeight="700" Background="#E8EAF6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Графики сбережений" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Button Content="Закрыть" Command="{Binding CloseSavingsChartsCommand}" Style="{StaticResource NavButton}" Margin="24,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Валюта" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                        <ComboBox SelectedValue="{Binding SavingsPanelCurrency}" SelectedValuePath="Tag" Width="200" Margin="0,0,0,12" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#e0e0e0" HorizontalAlignment="Left">
                            <ComboBoxItem Content="Гривны (UAH)" Tag="UAH"/>
                            <ComboBoxItem Content="Кроны (SEK)" Tag="SEK"/>
                            <ComboBoxItem Content="Доллары (USD)" Tag="USD"/>
                        </ComboBox>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Общая сумма:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock FontSize="18" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}">
                                <Run Text="{Binding PanelTotalSavings, StringFormat=N0, Mode=OneWay}"/>
                                <Run Text="{Binding SavingsPanelCurrencySymbol, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Text="Динамика по месяцам" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding SavingsMonthlyChart}" Margin="0,0,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                        <ProgressBar Grid.Column="1" Value="{Binding BarWidthPercent}" Maximum="100" Height="20" Margin="8,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding AmountText}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>

        <Border Grid.RowSpan="2" Panel.ZIndex="5" Background="#CC000000" Visibility="{Binding IsSavingsPanelOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" MouseDown="Overlay_MouseDown">
            <Border HorizontalAlignment="Center" VerticalAlignment="Stretch" Style="{StaticResource CardBorder}" Width="560" MaxWidth="900" Margin="40" MouseDown="Panel_MouseDown" MaxHeight="800" Background="#E8EAF6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="Мои сбережения" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Button Content="Закрыть" Command="{Binding CloseSavingsPanelCommand}" Style="{StaticResource NavButton}" Margin="24,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Показывать в:" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox SelectedValue="{Binding SavingsPanelCurrency}" SelectedValuePath="Tag" Width="180" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#e0e0e0">
                                <ComboBoxItem Content="Гривны (UAH)" Tag="UAH"/>
                                <ComboBoxItem Content="Кроны (SEK)" Tag="SEK"/>
                                <ComboBoxItem Content="Доллары (USD)" Tag="USD"/>
                            </ComboBox>
                            <TextBlock Text="Итого:" Foreground="{StaticResource TextSecondaryBrush}" Margin="24,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}">
                                <Run Text="{Binding PanelTotalSavings, StringFormat=N0, Mode=OneWay}"/>
                                <Run Text="{Binding SavingsPanelCurrencySymbol, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="Смотреть графики" Command="{Binding OpenSavingsChartsCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,8,0"/>
                        </StackPanel>
                        <TextBlock Text="Динамика по месяцам (итоги формируются автоматически)" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                        <ItemsControl ItemsSource="{Binding SavingsMonthlyChart}" Margin="0,0,0,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Label}" Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding AmountText}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button Content="+ Категория сбережений" Command="{Binding OpenAddSavingsCategoryCommand}" Style="{StaticResource NavButton}" Margin="0,0,8,0"/>
                            <Button Content="+ Счёт сбережений" Command="{Binding OpenAddSavingsCommand}" Style="{StaticResource PrimaryButton}"/>
                        </StackPanel>
                        <TextBlock Text="Категории сбережений" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding SavingsCategories}" Margin="0,0,0,12">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BackgroundHoverBrush}" CornerRadius="6" Padding="8,6" Margin="0,0,0,4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Content="Изменить" Command="{Binding DataContext.OpenEditSavingsCategoryCommand, ElementName=RootGrid}" CommandParameter="{Binding}" Style="{StaticResource NavButton}" Padding="6,2" Margin="0,0,4,0"/>
                                                <Button Content="✕" Command="{Binding DataContext.DeleteSavingsCategoryCommand, ElementName=RootGrid}" CommandParameter="{Binding}" Style="{StaticResource NavButton}" Foreground="#c62828" Padding="6,2"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding SavingsCategoryError}" Foreground="#c62828" FontSize="12" Margin="0,0,0,6" TextWrapping="Wrap"/>
                        <TextBlock Text="Счета" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding SavingsEntries}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource BackgroundHoverBrush}" CornerRadius="8" Padding="12,8" Margin="0,0,0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding CategoryName}" Foreground="{StaticResource TextSecondaryBrush}" MinWidth="80" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Entry.Name}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding ConvertedBalanceText}" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,12,0"/>
                                            <StackPanel Grid.Column="3" Orientation="Horizontal">
                                                <Button Content="Изменить" Command="{Binding DataContext.OpenEditSavingsCommand, ElementName=RootGrid}" CommandParameter="{Binding}" Style="{StaticResource NavButton}" Padding="8,4" Margin="0,0,4,0"/>
                                                <Button Content="✕" Command="{Binding DataContext.DeleteSavingsCommand, ElementName=RootGrid}" CommandParameter="{Binding}" Style="{StaticResource NavButton}" Foreground="#c62828" Padding="8,4"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Border>

        <Border Grid.RowSpan="2" Background="#CC000000" Visibility="{Binding IsAddTransactionOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" MouseDown="Overlay_MouseDown">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource CardBorder}" Width="380" MouseDown="Panel_MouseDown">
                <StackPanel>
                    <TextBlock Text="Новая операция" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Тип" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox SelectedValue="{Binding NewTransactionType}" SelectedValuePath="Tag" Margin="0,0,0,12" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#e0e0e0">
                        <ComboBoxItem Content="Расход" Tag="{x:Static models:TransactionType.Expense}"/>
                        <ComboBoxItem Content="Доход" Tag="{x:Static models:TransactionType.Income}"/>
                    </ComboBox>
                    <TextBlock Text="Категория" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding TransactionCategories}" SelectedItem="{Binding NewTransactionCategory}" DisplayMemberPath="Name" Margin="0,0,0,12" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#e0e0e0"/>
                    <TextBlock Text="Счёт (списать с / зачислить на)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding SavingsEntries}" SelectedItem="{Binding SelectedSavingsForTransaction}" DisplayMemberPath="Entry.Name" Margin="0,0,0,12" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#e0e0e0"/>
                    <TextBlock Text="Валюта операции" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox SelectedValue="{Binding NewTransactionCurrency}" SelectedValuePath="Tag" Margin="0,0,0,12" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#e0e0e0">
                        <ComboBoxItem Content="Шведская крона (SEK)" Tag="SEK"/>
                        <ComboBoxItem Content="Гривна (UAH)" Tag="UAH"/>
                        <ComboBoxItem Content="Доллар (USD)" Tag="USD"/>
                    </ComboBox>
                    <TextBlock Text="Сумма" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewTransactionAmount, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,12" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"/>
                    <TextBlock Text="Дата" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <DatePicker SelectedDate="{Binding NewTransactionDate}" Margin="0,0,0,12" Background="{StaticResource BackgroundCardBrush}"/>
                    <TextBlock Text="Комментарий (необяз.)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewTransactionNote, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,8" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" BorderBrush="#e0e0e0"/>
                    <TextBlock Text="{Binding SaveTransactionError}" Foreground="#c62828" FontSize="12" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" Command="{Binding CloseAddTransactionCommand}" Style="{StaticResource NavButton}" Margin="0,0,8,0"/>
                        <Button Content="Сохранить" Command="{Binding SaveTransactionCommand}" Style="{StaticResource PrimaryButton}" IsEnabled="{Binding CanSaveTransaction}"
                                                ToolTip="Сначала добавьте категорию в разделе «Категории»"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="2" Panel.ZIndex="15" Background="#CC000000" Visibility="{Binding IsAddCategoryOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" MouseDown="Overlay_MouseDown">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource CardBorder}" Width="360" MouseDown="Panel_MouseDown">
                <StackPanel>
                    <TextBlock Text="Новая категория" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Название" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewCategoryName, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,12" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"/>
                    <TextBlock Text="Тип" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox SelectedValue="{Binding NewCategoryType}" SelectedValuePath="Tag" Margin="0,0,0,16" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#e0e0e0">
                        <ComboBoxItem Content="Расход" Tag="{x:Static models:TransactionType.Expense}"/>
                        <ComboBoxItem Content="Доход" Tag="{x:Static models:TransactionType.Income}"/>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" Command="{Binding CloseAddCategoryCommand}" Style="{StaticResource NavButton}" Margin="0,0,8,0"/>
                        <Button Content="Сохранить" Command="{Binding SaveCategoryCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="2" Panel.ZIndex="15" Background="#CC000000" Visibility="{Binding IsEditFinanceCategoryOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" MouseDown="Overlay_MouseDown">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource CardBorder}" Width="340" MouseDown="Panel_MouseDown">
                <StackPanel>
                    <TextBlock Text="Изменить категорию" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Название" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditFinanceCategoryName, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,16" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" Command="{Binding CloseEditFinanceCategoryCommand}" Style="{StaticResource NavButton}" Margin="0,0,8,0"/>
                        <Button Content="Сохранить" Command="{Binding SaveEditFinanceCategoryCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <!-- Панель: Новый счёт сбережений (поверх панели «Мои сбережения») -->
        <Border Grid.RowSpan="2" Panel.ZIndex="15" Background="#CC000000" Visibility="{Binding IsAddSavingsOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" MouseDown="Overlay_MouseDown">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource CardBorder}" Width="380" MaxWidth="400" Margin="40" MouseDown="Panel_MouseDown">
                <StackPanel>
                    <TextBlock Text="Новый счёт сбережений" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Категория" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding SavingsCategories}" SelectedItem="{Binding NewSavingsCategory}" DisplayMemberPath="Name" Margin="0,0,0,12" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#e0e0e0"/>
                    <TextBlock Text="Название (например: Monobank, Trust Wallet)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewSavingsName, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,12" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"/>
                    <TextBlock Text="Валюта" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <ComboBox SelectedValue="{Binding NewSavingsCurrency}" SelectedValuePath="Tag" Margin="0,0,0,12" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" BorderBrush="#e0e0e0">
                        <ComboBoxItem Content="Гривны (UAH)" Tag="UAH"/>
                        <ComboBoxItem Content="Кроны (SEK)" Tag="SEK"/>
                        <ComboBoxItem Content="Доллары (USD)" Tag="USD"/>
                    </ComboBox>
                    <TextBlock Text="Баланс" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewSavingsBalance, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,16" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" Command="{Binding CloseAddSavingsCommand}" Style="{StaticResource NavButton}" Margin="0,0,8,0"/>
                        <Button Content="Сохранить" Command="{Binding SaveSavingsEntryCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="2" Panel.ZIndex="15" Background="#CC000000" Visibility="{Binding IsEditSavingsOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" MouseDown="Overlay_MouseDown">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource CardBorder}" Width="360" Margin="40" MouseDown="Panel_MouseDown">
                <StackPanel>
                    <TextBlock Text="Изменить баланс" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding EditSavingsItemName}" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                    <TextBlock Text="Новый баланс" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditSavingsBalance, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,16" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" Command="{Binding CloseEditSavingsCommand}" Style="{StaticResource NavButton}" Margin="0,0,8,0"/>
                        <Button Content="Сохранить" Command="{Binding SaveEditSavingsCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="2" Panel.ZIndex="15" Background="#CC000000" Visibility="{Binding IsAddSavingsCategoryOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" MouseDown="Overlay_MouseDown">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource CardBorder}" Width="340" Margin="40" MouseDown="Panel_MouseDown">
                <StackPanel>
                    <TextBlock Text="Новая категория сбережений" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Название (например: Крипта, Наличка, Банки)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewSavingsCategoryName, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,16" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" Command="{Binding CloseAddSavingsCategoryCommand}" Style="{StaticResource NavButton}" Margin="0,0,8,0"/>
                        <Button Content="Сохранить" Command="{Binding SaveSavingsCategoryCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="2" Background="#CC000000" Visibility="{Binding IsEditSavingsCategoryOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" MouseDown="Overlay_MouseDown">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource CardBorder}" Width="340" MouseDown="Panel_MouseDown">
                <StackPanel>
                    <TextBlock Text="Изменить категорию" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Название" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditSavingsCategoryName, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,16" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" Command="{Binding CloseEditSavingsCategoryCommand}" Style="{StaticResource NavButton}" Margin="0,0,8,0"/>
                        <Button Content="Сохранить" Command="{Binding SaveEditSavingsCategoryCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
