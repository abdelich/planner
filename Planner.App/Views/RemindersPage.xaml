<UserControl x:Class="Planner.App.Views.RemindersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundDarkBrush}">
    <Grid x:Name="RootGrid" Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="Напоминания" FontSize="28" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Border Visibility="{Binding ShowEmptyMessage, Converter={StaticResource BoolToVis}, FallbackValue=Visible}" Background="{StaticResource BackgroundCardBrush}" CornerRadius="12" Padding="32" VerticalAlignment="Top" Margin="0,0,0,16">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="Список напоминаний" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock Text="Загрузка…" Foreground="{StaticResource AccentLightBrush}" HorizontalAlignment="Center" Margin="0,0,0,8" Visibility="{Binding IsLoadingReminders, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="{Binding LoadError}" Foreground="#c62828" TextWrapping="Wrap" MaxWidth="420" HorizontalAlignment="Center" Margin="0,0,0,8" Visibility="{Binding LoadError, Converter={StaticResource StringToVisibilityConverter}}"/>
                    <TextBlock Text="Пока пусто. Нажмите «+ Новое напоминание», чтобы создать. У каждого напоминания будут кнопки «Изменить» и «Удалить»." Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" MaxWidth="420" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="Обновить список" Command="{Binding RefreshListCommand}" Style="{StaticResource NavButton}" Margin="0,0,12,0"/>
                        <Button Content="+ Добавить напоминание" Command="{Binding OpenAddPanelCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            <ScrollViewer VerticalScrollBarVisibility="Auto" Visibility="{Binding ShowEmptyMessage, Converter={StaticResource BoolToVisInverse}, FallbackValue=Collapsed}">
                <ItemsControl ItemsSource="{Binding Reminders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                                <StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Reminder.Title}" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding Reminder.IntervalMinutes, StringFormat='Каждые {0} мин'}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                                            <TextBlock Text="{Binding MonthProgressText, Mode=OneWay}" Foreground="{StaticResource AccentLightBrush}" Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="Изменить" Command="{Binding DataContext.OpenEditPanelCommand, ElementName=RootGrid}" CommandParameter="{Binding}" Style="{StaticResource NavButton}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <Button Content="Удалить" Command="{Binding DataContext.DeleteReminderCommand, ElementName=RootGrid}" CommandParameter="{Binding}" Style="{StaticResource NavButton}" Foreground="#f85149" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                    <ProgressBar Value="{Binding MonthProgressPercent, Mode=OneWay}" Maximum="100" Style="{StaticResource ProgressBarStyle}" Height="8" Margin="0,0,0,12"/>
                                    <TextBlock Text="Сегодня (отметить выполнение):" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>
                                    <ItemsControl ItemsSource="{Binding TodaySlots}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{StaticResource BackgroundHoverBrush}" CornerRadius="6" Padding="8,6" Margin="0,0,8,8">
                                                    <CheckBox IsChecked="{Binding Completed}" Command="{Binding ToggleCommand}" Style="{StaticResource CheckBoxStyle}" Content="{Binding TimeText}"/>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Border Grid.RowSpan="2" Background="#CC000000" Visibility="{Binding IsEditPanelOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" MouseDown="EditPanelOverlay_MouseDown">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource CardBorder}" Width="360" MouseDown="EditPanel_MouseDown">
                <StackPanel>
                    <TextBlock Text="Редактировать напоминание" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Название" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditReminderTitle, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,12" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"/>
                    <TextBlock Text="Интервал (минут)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding EditReminderIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,4" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" ToolTip="От 1 до 10080"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                        <Button Content="Отмена" Command="{Binding CloseEditPanelCommand}" Style="{StaticResource NavButton}" Margin="0,0,8,0"/>
                        <Button Content="Сохранить" Command="{Binding SaveEditReminderCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>

        <Border Grid.RowSpan="2" Background="#CC000000" Visibility="{Binding IsAddPanelOpen, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}" MouseDown="AddPanelOverlay_MouseDown">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource CardBorder}" Width="360" MouseDown="AddPanel_MouseDown">
                <StackPanel>
                    <TextBlock Text="Новое напоминание" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="Название" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewReminderTitle, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,12" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1"/>
                    <TextBlock Text="Интервал (минут)" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                    <TextBox Text="{Binding NewReminderIntervalMinutes, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" Margin="0,0,0,4" Background="{StaticResource BackgroundCardBrush}" Foreground="{StaticResource TextPrimaryBrush}" CaretBrush="{StaticResource TextPrimaryBrush}" BorderBrush="{StaticResource PrimaryBrush}" BorderThickness="1" ToolTip="От 1 до 10080 (макс. неделя)"/>
                    <TextBlock Text="От 1 до 10080 минут." Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,16"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Отмена" Command="{Binding CloseAddPanelCommand}" Style="{StaticResource NavButton}" Margin="0,0,8,0"/>
                        <Button Content="Сохранить" Command="{Binding SaveNewReminderCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</UserControl>
